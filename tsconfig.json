{
	"compilerOptions": {
		"target": "es2023",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"moduleDetection": "force",
		"outDir": "./dist",
    "rootDir": "./src",
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,

		"strict": true,
		"noUncheckedIndexedAccess": true,
		"exactOptionalPropertyTypes": true,
		"verbatimModuleSyntax": true,
		"isolatedModules": true,
		"skipLibCheck": true,

		"types": ["node"]
	},
	"include": ["src/**/*"]
}
