model BankAccount {
  id        Int      @id @default(autoincrement())
  balance   BigInt   @default(1000)
  userId    Int      @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt @map("updated_at")

	@@map("bank_accounts")
}